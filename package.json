{
  "name": "md2docx-plugin-template",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "clean": "turbo clean",
    "dev": "turbo dev",
    "format": "biome check . --write",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "sync": "turborepo-template-upgrade",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "preinstall": "tsx scripts/update-pm.ts",
    "prepare": "husky",
    "release": "tsx ./scripts/publish.ts",
    "upgrade": "tsx ./scripts/upgrade.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@changesets/cli": "^2.31.0",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^25.9.3",
    "husky": "^9.1.7",
    "tsx": "^4.22.4",
    "turbo": "^2.9.18",
    "turborepo-template-upgrade": "^0.8.0"
  },
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@promptshield/cli": "^1.2.0"
  }
}
